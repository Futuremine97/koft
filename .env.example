# Optional external reconstruction API configuration.
# Keep real keys in Vercel Environment Variables or local .env.local.
KOFT_RECON_API_URL=
KOFT_RECON_API_KEY=
KOFT_RECON_API_KIND=reconstruction
KOFT_RECON_API_TIMEOUT=120

# Multiple model registry example:
# KOFT_AI_MODELS_JSON={"nerf_cloud":{"url":"https://api.example.com/nerf","api_key_env":"NERF_API_KEY","kind":"nerf"},"mesh_api":{"url":"https://api.example.com/reconstruct","api_key_env":"MESH_API_KEY","kind":"reconstruction"}}
NERF_API_KEY=
MESH_API_KEY=
